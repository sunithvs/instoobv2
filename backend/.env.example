# Google OAuth (Cloud Console -> Credentials -> OAuth client ID -> Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback

# AES-GCM key for encrypting the refresh token at rest.
# Generate with: python -c "import os,base64;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
TOKEN_ENC_KEY=

# Session signing key (Starlette SessionMiddleware).
# Generate with: python -c "import secrets;print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# Only this email is allowed to authenticate.
ALLOWED_EMAIL=email

# Frontend origin (CORS + post-login redirect target).
FRONTEND_ORIGIN=http://localhost:5173

# Extra CORS origins, comma-separated (frontend domains hitting this API).
# FRONTEND_ORIGINS=https://instoobv2.vercel.app,http://instoob.radr.in

# Cross-site session cookie. When the frontend is on a DIFFERENT domain than
# this API, set these so the cookie is sent on cross-site fetch (HTTPS required):
#   SESSION_COOKIE_SAMESITE=none
#   SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false

# Optional: path to Netscape-format Instagram cookies file for yt-dlp.
IG_COOKIES_PATH=./ig_cookies.txt
